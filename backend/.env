# ============================================================
#               RSOD Agent Platform 环境变量配置
# ============================================================

# -------------------- API 密钥与模型 --------------------
# OpenAI API（可根据项目需要替换为其他兼容端点）
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Qwen API（DashScope 及兼容模式）
QWEN_API_KEY=sk-your-qwen-api-key
QWEN_API_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1   # 用于 LangChain OpenAI 客户端

# -------------------- 数据库（PostgreSQL） --------------------
# 使用统一连接字符串（推荐），与 docker-compose 服务匹配
DATABASE_URL=postgresql://admin:ltz78911@localhost:5658/agent

# 若需分解配置，可注释掉 DATABASE_URL，改用以下变量（但 DATABASE_URL 优先级更高）
# DB_HOST=localhost
# DB_PORT=5658
# DB_NAME=agent
# DB_USER=admin
# DB_PASSWORD=ltz78911

# -------------------- Redis --------------------
# 开发环境（本地 Docker）
REDIS_URL=redis://localhost:6379/0

# 也可单独指定主机和端口（备选）
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=             # 默认无密码

# -------------------- MinIO 对象存储 --------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rsod-images
MINIO_SECURE=false                 # 开发环境 false，生产启用 HTTPS 设为 true

# -------------------- 本地 LLM（Ollama，可选） --------------------
USE_LOCAL_LLM=false                # 是否启用本地模型
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b            # 可根据实际下载的模型修改

# -------------------- JWT 认证 --------------------
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# -------------------- 应用基础配置 --------------------
APP_NAME=RSOD Agent Platform
APP_VERSION=0.1.0
DEBUG=true                         # 生产环境设为 false
LOG_LEVEL=INFO                     # 可选 DEBUG, INFO, WARNING, ERROR

# -------------------- CORS 跨域配置 --------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080